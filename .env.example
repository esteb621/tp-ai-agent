# ── Modèle Mistral via Ollama (TriageBot, CommsBot, ArrBot) ────────────────
# Installation : https://ollama.ai/
# Commandes à exécuter UNE FOIS avant de démarrer l'application :
#   ollama pull mistral
#   ollama pull llama3.2
#   ollama serve   (doit tourner en arrière-plan)
OLLAMA_BASE_URL=http://localhost:11434

# ── Discord Bot ─────────────────────────────────────────────────────────────
# 1. Crée ton bot sur https://discord.com/developers/applications
# 2. Onglet "Bot" → copie le Token
# 3. Invite le bot avec OAuth2 → scopes: bot → permissions: Send Messages, Read Messages
DISCORD_BOT_TOKEN=ton_token_discord_ici

# ID du channel Discord où envoyer les notifications de support
# Active Mode Développeur dans Discord → clic droit sur le channel → Copier l'identifiant
DISCORD_CHANNEL_ID=123456789012345678
